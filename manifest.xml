<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  ═══════════════════════════════════════════════════════════════════════════
  IVP IRR Analytics Engine — Excel Web Add-in Manifest
  ═══════════════════════════════════════════════════════════════════════════

  SETUP INSTRUCTIONS:
  1. Generate a GUID at https://guidgenerator.com/ and replace YOUR-GUID-HERE
  2. Host all files on GitHub Pages (or any HTTPS server)
  3. Replace all occurrences of https://raagrawal-cell.github.io/irr-excel-addin with your actual URL
     e.g. https://raagrawal-cell.github.io/irr-excel-addin

  TO SIDELOAD IN EXCEL:
    Desktop: Insert → Add-ins → Manage My Add-ins → Upload My Add-in → select this file
    Excel Online: Insert → Office Add-ins → Upload My Add-in → select this file

  ═══════════════════════════════════════════════════════════════════════════
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- ── Identity ─────────────────────────────────────────────────────── -->
  <Id>a7cac51e-2f66-4b66-8324-49ebc8d70384</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Indus Valley Partners</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <!-- ── Display ──────────────────────────────────────────────────────── -->
  <DisplayName DefaultValue="IVP IRR Analytics Engine"/>
  <Description DefaultValue="PE/VC IRR computation, scenario simulation, reverse IRR backsolve, and management commentary for fund analytics."/>

  <!-- 32×32 and 80×80 icon URLs — replace with hosted IVP logo PNGs -->
  <IconUrl DefaultValue="https://raagrawal-cell.github.io/irr-excel-addin/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://raagrawal-cell.github.io/irr-excel-addin/assets/icon-80.png"/>

  <SupportUrl DefaultValue="https://www.ivp.in"/>
  <AppDomains>
    <!-- Add any external domains your add-in fetches from -->
    <AppDomain>https://api.anthropic.com</AppDomain>
  </AppDomains>

  <!-- ── Host: Excel only ─────────────────────────────────────────────── -->
  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>

  <!-- ── Default task pane entry point ────────────────────────────────── -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://raagrawal-cell.github.io/irr-excel-addin/taskpane.html"/>
  </DefaultSettings>

  <!-- ── Permissions: ReadWriteDocument to write Simulation_Log etc. ──── -->
  <Permissions>ReadWriteDocument</Permissions>

  <!-- ── Version Overrides: Ribbon button (Office 2016+, M365) ─────────
       Adds an "IVP IRR" tab to the Excel ribbon with a single launch button.
       Remove this entire <VersionOverrides> block if you want sideload-only.
  ─────────────────────────────────────────────────────────────────────── -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">

        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>

          <FunctionFile resid="Commands.Url"/>

          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="CommandsGroup">
                <Label resid="CommandsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>

                <!-- Main launch button -->
                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>

      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://raagrawal-cell.github.io/irr-excel-addin/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://raagrawal-cell.github.io/irr-excel-addin/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://raagrawal-cell.github.io/irr-excel-addin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl"  DefaultValue="https://www.ivp.in"/>
        <bt:Url id="Commands.Url"             DefaultValue="https://raagrawal-cell.github.io/irr-excel-addin/commands.html"/>
        <bt:Url id="Taskpane.Url"             DefaultValue="https://raagrawal-cell.github.io/irr-excel-addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title"       DefaultValue="IVP IRR Analytics Engine"/>
        <bt:String id="CommandsGroup.Label"    DefaultValue="IVP Analytics"/>
        <bt:String id="TaskpaneButton.Label"   DefaultValue="IRR Engine"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Open the IVP IRR Analytics Engine to compute IRR, run simulations, and generate IC commentary."/>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open IRR Analytics Engine — compute, simulate, backsolve, and report."/>
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>

</OfficeApp>
